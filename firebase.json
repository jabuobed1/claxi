{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "claxi",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/verify-paystack",
        "function": "verifyPaystack"
      },
      {
        "source": "/zoom-auth-start",
        "function": "zoomAuthStart"
      },
      {
        "source": "/zoom-create-meeting",
        "function": "zoomCreateMeeting"
      },
      {
        "source": "/zoom-oauth-callback",
        "function": "zoomOAuthCallback"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
